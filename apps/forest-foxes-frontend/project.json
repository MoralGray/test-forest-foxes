{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "name": "forest-foxes-frontend",
    "project": {
        "type": "application"
    },
    "sourceRoot": "apps/forest-foxes-frontend/src",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm run build",
                "cwd": "apps/forest-foxes-frontend"
            }
        },
        "dev": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm run dev",
                "cwd": "apps/forest-foxes-frontend"
            },
            "forwardAllArgs": true,
            "continuous": true
        },
        "lint": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm run lint",
                "cwd": "apps/forest-foxes-frontend"
            }
        },
        "typecheck": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm run typecheck",
                "cwd": "apps/forest-foxes-frontend"
            }
        },
        "test": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm run test",
                "cwd": "apps/forest-foxes-frontend"
            }
        },
        "test-e2e": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm run test:e2e",
                "cwd": "apps/forest-foxes-frontend"
            }
        }
    }
}
