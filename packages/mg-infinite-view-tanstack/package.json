{
    "name": "@mg-nx-forge/mg-infinite-view-tanstack",
    "version": "0.0.1",
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "scripts": {
        "build": "tsc -b",
